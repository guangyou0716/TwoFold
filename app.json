{
  "expo": {
    "name": "TwoFold",
    "slug": "twofold-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.twofold.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.twofold.app",
      "adaptiveIcon": {
        "backgroundColor": "#0A0B10",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-av",
      [
        "expo-image-picker",
        {
          "photosPermission": "TwoFold uses your photo library to let you pin memories to your milestones.",
          "cameraPermission": "TwoFold uses your camera to capture moments together."
        }
      ],
      "expo-video",
      "expo-notifications",
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "useEmulators": false,
      "eas": {
        "projectId": "c5855642-099c-4c06-83b0-9636384bf611"
      }
    },
    "owner": "gy16",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/c5855642-099c-4c06-83b0-9636384bf611"
    }
  }
}
